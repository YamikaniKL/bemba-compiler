{
  "name": "bembajs-core",
  "version": "1.4.28",
  "description": "BembaJS Core - Compiler and runtime for Bemba language with conditionals, loops, and async/await support",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "bembajs-core": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./lexer": {
      "require": "./dist/lexer.js",
      "import": "./dist/lexer.mjs",
      "types": "./dist/lexer.d.ts"
    },
    "./parser": {
      "require": "./dist/parser.js",
      "import": "./dist/parser.mjs",
      "types": "./dist/parser.d.ts"
    },
    "./transformer": {
      "require": "./dist/transformer.js",
      "import": "./dist/transformer.mjs",
      "types": "./dist/transformer.d.ts"
    },
    "./generator": {
      "require": "./dist/generator.js",
      "import": "./dist/generator.mjs",
      "types": "./dist/generator.d.ts"
    },
    "./vite-plugin-bemba": {
      "require": "./dist/vite-plugin-bemba.js",
      "import": "./dist/vite-plugin-bemba.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.js",
    "dev": "node build.js --watch",
    "test": "node test/index.js && node test/smoke-export.js",
    "lint": "node -e \"console.log('bembajs-core lint: no standalone lint target yet')\"",
    "format": "node -e \"console.log('bembajs-core format: no standalone format target yet')\"",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "keywords": [
    "bemba",
    "compiler",
    "parser",
    "lexer",
    "ast"
  ],
  "author": "Yamikani Kalonge and Bemba Team",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "esbuild": "^0.28.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "^8.0.10",
    "@vitejs/plugin-react": "^6.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YamikaniKL/bemba-compiler.git",
    "directory": "packages/bembajs-core"
  }
}
