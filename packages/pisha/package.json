{
  "name": "bembajs-pisha",
  "version": "1.4.36",
  "description": "Pisha - The Vite-based build tool for BembaJS",
  "main": "./src/index.js",
  "type": "module",
  "bin": {
    "pisha": "./bin/pisha.js"
  },
  "scripts": {
    "dev": "node src/cli.js dev",
    "build": "node src/cli.js build",
    "preview": "node src/cli.js preview",
    "test": "node -e \"console.log('pisha: tests are not configured yet')\"",
    "lint": "node -e \"console.log('pisha lint: no standalone lint target yet')\"",
    "format": "node -e \"console.log('pisha format: no standalone format target yet')\"",
    "clean": "node -e \"console.log('pisha clean: nothing to clean')\""
  },
  "keywords": [
    "bembajs",
    "vite",
    "build-tool",
    "pisha",
    "compiler",
    "react",
    "bemba-language"
  ],
  "author": "Yamikani K Alonge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YamikaniKL/bemba-compiler.git"
  },
  "dependencies": {
    "vite": "^8.0.10",
    "bembajs": "^1.4.36"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

