{
  "name": "bembajs",
  "version": "1.4.1",
  "description": "BembaJS - A Next.js-like framework for programming in Bemba language with full control flow and Chakra UI support",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "bemba": "./bin/bemba.js"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "require": "./dist/cli.js",
      "import": "./dist/cli.mjs"
    },
    "./server": {
      "require": "./dist/server.js",
      "import": "./dist/server.mjs"
    }
  },
  "files": [
    "dist",
    "bin",
    "vscode"
  ],
  "scripts": {
    "build": "node build.js",
    "dev": "node bin/bemba.js tungulula",
    "test": "node test/index.js",
    "lint": "node -e \"console.log('bembajs lint: no standalone lint target yet')\"",
    "format": "node -e \"console.log('bembajs format: no standalone format target yet')\"",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "keywords": [
    "bemba",
    "javascript",
    "framework",
    "nextjs",
    "react",
    "compiler",
    "zambia",
    "cli"
  ],
  "author": "Yamikani Kalonge and Bemba Team",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "bembajs-core": "^1.4.1",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "prompts": "^2.4.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "^8.0.10"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=16.0.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "bemba",
        "aliases": [
          "Bemba",
          "bemba"
        ],
        "extensions": [
          ".bemba"
        ],
        "configuration": "./vscode/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bemba",
        "scopeName": "source.bemba",
        "path": "./vscode/bemba.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "bemba",
        "path": "./vscode/snippets.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YamikaniKL/bemba-compiler.git",
    "directory": "packages/bembajs"
  }
}
